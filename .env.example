NODE_ENV=production
PORT=3000

# Editor defaults (can be changed in Settings UI)
NORA_WRITER_EDITOR=davinci-resolve

# Text-provider defaults (can be changed in Settings UI)
NORA_WRITER_TEXT_PROVIDER=anthropic
NORA_WRITER_MODEL=claude-sonnet-4-6
NORA_WRITER_MODEL_OPTIONS=claude-sonnet-4-6,claude-opus-4-6,claude-sonnet-4-5-20250929
NORA_WRITER_MODEL_PINNED=claude-sonnet-4-6,claude-opus-4-6,claude-sonnet-4-5-20250929

# Optional fallback model catalogs per provider
NORA_WRITER_OPENAI_MODEL_OPTIONS=gpt-5-mini,gpt-4.1-mini,gpt-4o-mini
NORA_WRITER_XAI_MODEL_OPTIONS=grok-4-0709,grok-3-mini
NORA_WRITER_GEMINI_MODEL_OPTIONS=gemini-2.5-pro,gemini-2.5-flash
NORA_WRITER_OPENROUTER_TEXT_MODELS=anthropic/claude-sonnet-4.5,google/gemini-2.5-pro,openai/gpt-5-mini
NORA_WRITER_OLLAMA_MODEL_OPTIONS=llama3.1:8b,qwen2.5:7b,mistral:7b

# API keys (set only what you need)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# Optional custom API base URLs
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1
XAI_BASE_URL=https://api.x.ai/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Image analysis + generation routing
NORA_WRITER_IMAGE_ANALYSIS_PROVIDER=claude
NORA_WRITER_NANOBANANA_MODEL=google/gemini-2.5-pro
NORA_WRITER_IMAGE_MODELS=google/gemini-2.5-pro,google/gemini-2.5-flash-image-preview,google/gemini-2.5-flash

# Thumbnail research context file
NORA_WRITER_THUMBNAIL_RESEARCH_PATH=./data/thumbnail_research_bible.md
