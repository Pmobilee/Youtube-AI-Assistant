NODE_ENV=production
PORT=3000

# Network binding / public URL
YAA_BIND_HOST=127.0.0.1
YAA_PUBLIC_BASE_URL=http://127.0.0.1:3000

# Identity defaults (can be changed in Settings UI)
YAA_USER_NAME=Creator
YAA_EDITOR=davinci-resolve

# Assistant identity + personality (used in system prompts and UI)
YAA_ASSISTANT_NAME=Assistant
YAA_ASSISTANT_EMOJI=🤖
YAA_ASSISTANT_PERSONALITY=Direct, practical, creator-focused. Give actionable guidance and challenge weak ideas.
YAA_ASSISTANT_COMMUNICATION=Keep replies concise, specific, and useful. Prefer bullets and concrete next steps over long prose.
YAA_CREATOR_PROFILE=Creator profile: makes YouTube videos and prefers practical, iterative collaboration.

# Text-provider defaults (can be changed in Settings UI)
YAA_TEXT_PROVIDER=anthropic
YAA_MODEL=claude-sonnet-4-6
YAA_MODEL_OPTIONS=claude-sonnet-4-6,claude-opus-4-6,claude-sonnet-4-5-20250929
YAA_MODEL_PINNED=claude-sonnet-4-6,claude-opus-4-6,claude-sonnet-4-5-20250929

# Optional fallback model catalogs per provider
YAA_OPENAI_MODEL_OPTIONS=gpt-5-mini,gpt-4.1-mini,gpt-4o-mini
YAA_XAI_MODEL_OPTIONS=grok-4-0709,grok-3-mini
YAA_GEMINI_MODEL_OPTIONS=gemini-2.5-pro,gemini-2.5-flash
YAA_OPENROUTER_TEXT_MODELS=anthropic/claude-sonnet-4.5,google/gemini-2.5-pro,openai/gpt-5-mini
YAA_OLLAMA_MODEL_OPTIONS=llama3.1:8b,qwen2.5:7b,mistral:7b

# API keys (set only what you need)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# Optional custom API base URLs
YAA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
YAA_OPENAI_BASE_URL=https://api.openai.com/v1
YAA_XAI_BASE_URL=https://api.x.ai/v1
YAA_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Image analysis + generation routing
YAA_IMAGE_ANALYSIS_PROVIDER=claude
YAA_NANOBANANA_MODEL=google/gemini-2.5-pro
YAA_IMAGE_MODELS=google/gemini-2.5-pro,google/gemini-2.5-flash-image-preview,google/gemini-2.5-flash

# Thumbnail research context file
YAA_THUMBNAIL_RESEARCH_PATH=./data/thumbnail_research_bible.md

# Optional manual balance display in UI top bar
# YAA_CLAUDE_CREDITS_DISPLAY=$XX.XX left
