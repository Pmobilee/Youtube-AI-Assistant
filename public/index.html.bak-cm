<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nora Writer</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <!-- CodeMirror 5 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/dracula.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/markdown/markdown.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/selection/mark-selection.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/search/searchcursor.min.js"></script>
</head>
<body>
  <div id="app">
    <!-- Library View -->
    <div id="library-view" class="view active">
      <header class="library-header">
        <div class="header-left">
          <h1>🌺 Nora Writer</h1>
          <p class="subtitle">Video Script Workspace</p>
        </div>
        <div class="header-right">
          <button id="theme-toggle" class="btn btn-icon" title="Toggle dark mode">🌙</button>
          <button id="new-video-btn" class="btn btn-primary">+ New Video</button>
        </div>
      </header>
      <main class="library-grid" id="video-grid">
        <!-- Video cards rendered here -->
      </main>
      <div id="empty-state" class="empty-state hidden">
        <div class="empty-icon">📝</div>
        <h2>No videos yet</h2>
        <p>Create your first video project to get started</p>
        <button class="btn btn-primary" onclick="createNewVideo()">+ New Video</button>
      </div>
    </div>

    <!-- Workspace View -->
    <div id="workspace-view" class="view">
      <header class="workspace-header">
        <div class="header-left">
          <button id="back-btn" class="btn btn-ghost">← Back</button>
          <input id="video-title" class="title-input" placeholder="Video Title" />
          <select id="video-status" class="status-select">
            <option value="draft">📋 Draft</option>
            <option value="in-progress">✏️ In Progress</option>
            <option value="complete">✅ Complete</option>
          </select>
        </div>
        <div class="header-right">
          <span id="save-indicator" class="save-indicator">Saved</span>
          <button id="theme-toggle-ws" class="btn btn-icon" title="Toggle dark mode">🌙</button>
        </div>
      </header>

      <div class="workspace-container">
        <!-- Left Pane: Chat -->
        <div class="pane chat-pane" id="chat-pane">
          <div class="pane-header">
            <h3>💬 Chat with Kona</h3>
            <button class="btn btn-ghost btn-sm" id="upload-btn" title="Upload image">📎</button>
            <input type="file" id="file-input" accept="image/*" style="display:none">
          </div>
          <div class="chat-messages" id="chat-messages">
            <div class="chat-welcome">
              <p>🌺 <strong>Kona here!</strong> Ready to work on this video together. What are we making?</p>
            </div>
          </div>
          <div id="uploaded-images" class="uploaded-images"></div>
          <div id="token-bar" class="token-bar">
            <div class="token-fill" id="token-fill"></div>
            <span class="token-text" id="token-text">0 / 300K tokens</span>
          </div>
          <div class="chat-input-container">
            <textarea id="chat-input" placeholder="Message Kona..." rows="1"></textarea>
            <button id="send-btn" class="btn btn-primary btn-send">Send</button>
          </div>
        </div>

        <!-- Resize Handle -->
        <div class="resize-handle" id="resize-handle"></div>

        <!-- Right Pane: Editor -->
        <div class="pane editor-pane" id="editor-pane">
          <div class="pane-header">
            <h3>📝 Script Editor</h3>
            <div class="editor-tabs">
              <button class="tab active" data-tab="script">Script</button>
              <button class="tab" data-tab="description">Description</button>
              <button class="tab" data-tab="voiceover">Voiceover</button>
              <button class="tab" data-tab="thumbnails">Thumbnails</button>
            </div>
          </div>
          <div class="editor-content">
            <div class="editor-area active" id="editor-script">
              <div id="script-editor" class="cm-editor-wrap" data-placeholder="# Opening Hook&#10;&#10;Start writing your script here...&#10;&#10;# Main Content&#10;&#10;# Outro"></div>
            </div>
            <div class="editor-area" id="editor-description">
              <div id="description-editor" class="cm-editor-wrap" data-placeholder="Video description for YouTube..."></div>
            </div>
            <div class="editor-area" id="editor-voiceover">
              <div id="voiceover-editor" class="cm-editor-wrap" data-placeholder="Voiceover notes, tone directions, timing cues..."></div>
            </div>
            <div class="editor-area" id="editor-thumbnails">
              <div id="thumbnails-editor" class="cm-editor-wrap" data-placeholder="Thumbnail concepts and ideas..."></div>
              <div id="thumbnail-gallery" class="thumbnail-gallery"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- New Video Modal -->
  <div id="modal-overlay" class="modal-overlay hidden">
    <div class="modal">
      <h2>New Video Project</h2>
      <input id="new-video-title" class="modal-input" placeholder="Video title..." autofocus />
      <div class="modal-actions">
        <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
        <button class="btn btn-primary" onclick="confirmNewVideo()">Create</button>
      </div>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="delete-overlay" class="modal-overlay hidden">
    <div class="modal">
      <h2>Delete Video?</h2>
      <p>This will permanently delete this video and all its content.</p>
      <div class="modal-actions">
        <button class="btn btn-ghost" onclick="closeDeleteModal()">Cancel</button>
        <button class="btn btn-danger" id="confirm-delete-btn">Delete</button>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
